{% extends "layouts/base.html.twig" %}

{% block title %}Contacts - Nice Volley Ball{% endblock %}

{% block content %}
<div class="space-y-6">
    <!-- Header -->
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
        <div>
            <h1 class="text-3xl font-bold text-gray-800">Gestion des Contacts</h1>
            <p class="text-gray-500">Gérez vos contacts et segments Brevo.</p>
        </div>
        <div class="flex items-center gap-4">
            <div class="hidden sm:flex items-center gap-2 px-4 h-10 bg-white rounded-2xl border border-gray-100 shadow-sm">
                <div class="text-right">
                    <p class="text-[10px] uppercase tracking-wider text-gray-400 font-bold leading-none">Total Contacts</p>
                    <p class="text-lg font-black text-principal" id="total-contacts">...</p>
                </div>
            </div>
            <button type="button" id="btn-export-brevo" class="btn btn-sm h-10 bg-secondaire hover:bg-secondaire/90 text-principal border-none rounded-xl px-4 normal-case font-bold gap-2">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v2a2 2 0 002 2h12a2 2 0 002-2v-2M12 12V3m0 0L8 7m4-4l4 4"></path></svg>
                Exporter vers Brevo
            </button>
            <div id="api-status" class="text-xs px-3 py-1 bg-white border border-gray-100 rounded-full text-gray-400 shadow-sm flex items-center gap-2">
                <span class="w-2 h-2 bg-gray-300 rounded-full" id="status-dot"></span>
                Statut API : En attente
            </div>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
        <!-- Sidebar : Groupes -->
        <aside class="lg:col-span-3 space-y-4">
            <div class="bg-white rounded-3xl p-6 shadow-sm border border-gray-100 h-full">
                <div class="flex items-center justify-between mb-6">
                    <h2 class="text-lg font-bold text-gray-800">Groupes</h2>
                    <div class="flex items-center gap-2">
                        <span class="badge badge-sm badge-ghost opacity-50" id="group-count">0</span>
                        <span id="total-groupes" class="hidden">0</span>
                    </div>
                </div>
                
                <nav id="groupes-list" class="space-y-2 max-h-[60vh] overflow-y-auto pr-2 custom-scrollbar">
                    <!-- Skeletons pendant le chargement -->
                    <div class="animate-pulse space-y-3">
                        <div class="h-12 bg-gray-50 rounded-2xl w-full"></div>
                        <div class="h-12 bg-gray-50 rounded-2xl w-full"></div>
                        <div class="h-12 bg-gray-50 rounded-2xl w-full"></div>
                    </div>
                </nav>
            </div>
        </aside>

        <!-- Main : Liste des Contacts -->
        <section class="lg:col-span-9 space-y-4">
            <div class="bg-white rounded-3xl p-6 shadow-sm border border-gray-100 flex flex-col min-h-[600px]">
                <!-- Toolbar -->
                <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-6">
                    <h2 class="text-xl font-bold text-gray-800" id="contacts-title">Tous les contacts</h2>
                    
                    <div class="flex-1 max-w-md mx-4">
                        <div class="relative group">
                            <span class="absolute inset-y-0 left-0 pl-3 flex items-center text-gray-400 group-focus-within:text-principal transition-colors">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
                                </svg>
                            </span>
                            <input type="text" 
                                   id="search-contacts" 
                                   class="block w-full pl-10 pr-4 py-2 bg-gray-50 border border-transparent focus:bg-white focus:border-principal focus:ring-0 rounded-2xl text-sm transition-all"
                                   placeholder="Rechercher un contact (nom, email, tel...)"
                            >
                        </div>
                    </div>

                    <div class="flex items-center gap-2">
                        <button type="button" id="btn-supprimer-liste" class="btn btn-sm bg-red-500 hover:bg-red-600 text-white border-none rounded-xl px-4 normal-case hidden">
                            Supprimer la liste
                        </button>
                    </div>
                </div>

                <!-- Liste -->
                <div id="contacts-list" class="flex-1 space-y-3 overflow-y-auto max-h-[65vh] pr-2 custom-scrollbar">
                    <!-- Injecté par JS -->
                </div>

                <!-- Pagination -->
                <div class="flex items-center justify-between mt-6 pt-6 border-t border-gray-50">
                    <button type="button" id="btn-precedent" class="btn btn-sm btn-ghost gap-2 normal-case disabled:opacity-30">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
                        Précédent
                    </button>
                    <span id="page-info" class="text-sm font-medium text-gray-400">Page 1</span>
                    <button type="button" id="btn-suivant" class="btn btn-sm btn-ghost gap-2 normal-case disabled:opacity-30">
                        Suivant
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
                    </button>
                </div>
            </div>
        </section>

    </div>
</div>
{% endblock %}

{% block scripts %}
    <!-- Modale Export Brevo -->
    <dialog id="modal-export-brevo" class="modal">
        <div class="modal-box max-w-4xl rounded-3xl p-0 overflow-hidden">
            <!-- En-tête -->
            <div class="flex items-center justify-between px-6 py-5 bg-principal text-white">
                <div>
                    <h3 class="text-lg font-bold">Exporter vers Brevo</h3>
                    <p class="text-xs text-white/60">Sélectionnez les groupes/listes et/ou les contacts à synchroniser. Chaque groupe crée (ou réutilise) une liste Brevo.</p>
                </div>
                <form method="dialog">
                    <button class="btn btn-sm btn-circle btn-ghost text-white" aria-label="Fermer">✕</button>
                </form>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 p-6">
                <!-- Groupes / listes -->
                <div class="flex flex-col">
                    <div class="flex items-center justify-between mb-3">
                        <h4 class="font-bold text-gray-800">Groupes / listes <span class="text-gray-400 font-normal text-sm">(→ listes Brevo)</span></h4>
                        <label class="label cursor-pointer gap-2 p-0">
                            <span class="text-xs text-gray-500">Tout</span>
                            <input type="checkbox" id="export-select-all-groupes" class="checkbox checkbox-primary checkbox-xs" />
                        </label>
                    </div>
                    <div id="export-groupes-list" class="space-y-2 max-h-[45vh] overflow-y-auto pr-2 custom-scrollbar">
                        <div class="animate-pulse space-y-2">
                            <div class="h-10 bg-gray-50 rounded-xl w-full"></div>
                            <div class="h-10 bg-gray-50 rounded-xl w-full"></div>
                        </div>
                    </div>
                </div>

                <!-- Contacts -->
                <div class="flex flex-col">
                    <div class="flex items-center justify-between mb-3">
                        <h4 class="font-bold text-gray-800">Contacts</h4>
                        <label class="label cursor-pointer gap-2 p-0">
                            <span class="text-xs text-gray-500">Tout</span>
                            <input type="checkbox" id="export-select-all-contacts" class="checkbox checkbox-primary checkbox-xs" />
                        </label>
                    </div>
                    <input type="text" id="export-contacts-search" placeholder="Rechercher un contact…"
                           class="input input-sm input-bordered rounded-xl mb-3 w-full" />
                    <div id="export-contacts-list" class="space-y-2 max-h-[40vh] overflow-y-auto pr-2 custom-scrollbar">
                        <div class="animate-pulse space-y-2">
                            <div class="h-10 bg-gray-50 rounded-xl w-full"></div>
                            <div class="h-10 bg-gray-50 rounded-xl w-full"></div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Pied : résultat + actions -->
            <div class="px-6 pb-6">
                <div id="export-result" class="hidden text-sm rounded-xl p-3 mb-4"></div>
                <div class="flex items-center justify-between gap-4">
                    <span id="export-selection-info" class="text-xs text-gray-400">Aucune sélection</span>
                    <div class="flex items-center gap-2">
                        <form method="dialog">
                            <button class="btn btn-sm btn-ghost normal-case">Annuler</button>
                        </form>
                        <button type="button" id="btn-lancer-export"
                                class="btn btn-sm bg-principal hover:bg-principal/90 text-white border-none rounded-xl px-5 normal-case gap-2">
                            <span class="loading loading-spinner loading-xs hidden" id="export-spinner"></span>
                            Lancer l'export
                        </button>
                    </div>
                </div>
            </div>
        </div>
        <form method="dialog" class="modal-backdrop">
            <button>Fermer</button>
        </form>
    </dialog>

    <!-- Modal Suppression Liste -->
    <input type="checkbox" id="modal-suppression-liste" class="modal-toggle" />
    <div class="modal">
        <div class="modal-box bg-white rounded-3xl p-8 relative">
            <h3 class="font-bold text-2xl text-gray-800 mb-4">Supprimer la liste ?</h3>
            <p class="py-4 text-gray-600 leading-relaxed">
                Êtes-vous sûr de vouloir supprimer la liste <span id="nom-liste-a-supprimer" class="font-bold text-principal"></span> du dashboard ?
            </p>
            <div class="bg-amber-50 border-l-4 border-amber-400 p-4 mb-6">
                <div class="flex">
                    <div class="flex-shrink-0 pt-0.5">
                        <svg class="h-5 w-5 text-amber-400" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
                        </svg>
                    </div>
                    <div class="ml-3">
                        <p class="text-sm text-amber-700">
                            Cette action supprimera la liste de votre dashboard, mais <strong>cela n'aura aucun impact sur Brevo</strong>. 
                            Si vous souhaitez purger vos listes Brevo, vous devez le faire directement depuis votre compte Brevo.
                        </p>
                    </div>
                </div>
            </div>
            <div class="modal-action flex gap-3">
                <label for="modal-suppression-liste" class="btn btn-ghost rounded-2xl normal-case">Annuler</label>
                <button type="button" id="confirm-supprimer-liste" class="btn bg-red-500 hover:bg-red-600 text-white border-none rounded-2xl px-8 normal-case">
                    Confirmer la suppression
                </button>
            </div>
        </div>
        <label class="modal-backdrop" for="modal-suppression-liste">Fermer</label>
    </div>

    <script type="module" src="/frontend/src/script/total-contact.js" defer></script>
    
    <!-- Modal Succès Sync -->
    <input type="checkbox" id="modal-success-sync" class="modal-toggle" />
    <div class="modal">
        <div class="modal-box bg-white rounded-3xl p-8 relative flex flex-col items-center text-center">
            <div class="w-20 h-20 bg-green-100 rounded-full flex items-center justify-center mb-6">
                <svg class="w-10 h-10 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path>
                </svg>
            </div>
            <h3 class="font-bold text-2xl text-gray-800 mb-2">Synchronisation réussie !</h3>
            <p class="text-gray-600 mb-8">
                Vos contacts ont été transférés avec succès vers Brevo.
            </p>
            <div class="modal-action w-full">
                <label for="modal-success-sync" class="btn bg-principal hover:bg-principal/90 text-white border-none rounded-2xl w-full normal-case">Super !</label>
            </div>
        </div>
        <label class="modal-backdrop" for="modal-success-sync">Fermer</label>
    </div>
{% endblock %}
