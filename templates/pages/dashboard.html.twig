{% extends "layouts/base.html.twig" %}

{% block title %}Dashboard - Nice Volley Ball{% endblock %}

{% block content %}
<div class="flex flex-col space-y-4 h-[calc(100vh-4rem)]">
    <!-- Header Page -->
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-3 shrink-0">
        <div>
            <h1 class="text-2xl font-bold text-gray-800">Tableau de bord</h1>
            <p class="text-xs text-gray-500">Bienvenue sur votre interface de gestion Nice Volley Ball.</p>
        </div>
        <div class="flex flex-wrap items-center gap-3">
            <div class="tooltip tooltip-bottom before:text-xs before:max-w-[200px]" data-tip="Importez toutes les données en provenance de vos événements organisés sur WeezEvent">
                <button class="btn btn-sm md:btn-md bg-principal hover:bg-principal/90 text-white border-none rounded-xl shadow-md shadow-principal/20 px-4 transition-all hover:scale-105 active:scale-95">
                    <svg class="w-4 h-4 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path></svg>
                    Synchro WeezEvent
                </button>
            </div>
            <div class="tooltip tooltip-bottom before:text-xs before:max-w-[200px]" data-tip="Synchronisez les données de votre Dashboard avec vos listings Brevo">
                <button class="btn btn-sm md:btn-md bg-secondaire hover:bg-secondaire/90 text-principal border-none rounded-xl shadow-md shadow-secondaire/20 px-4 transition-all hover:scale-105 active:scale-95">
                    <svg class="w-4 h-4 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path></svg>
                    Synchro Brevo
                </button>
            </div>
            <div class="flex items-center gap-2 text-xs text-gray-400 bg-white px-3 py-1.5 rounded-lg shadow-sm border border-gray-100 h-fit">
                <span class="flex items-center gap-1.5">
                    <span class="w-2 h-2 bg-green-500 rounded-full animate-pulse"></span>
                    Système opérationnel
                </span>
            </div>
        </div>
    </div>

    <!-- Stats Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-4 gap-4 shrink-0">
        <!-- Total Contacts -->
        <div class="bg-white rounded-2xl p-4 shadow-sm border border-gray-100 flex flex-col justify-between hover:shadow-md transition-shadow">
            <div class="flex items-center justify-between mb-2">
                <div class="p-2 bg-blue-50 text-blue-600 rounded-xl">
                    <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
                </div>
                <span class="text-green-500 text-xs font-bold bg-green-50 px-1.5 py-0.5 rounded-md">+10%</span>
            </div>
            <div>
                <p class="text-gray-400 text-xs font-medium uppercase tracking-wider">Contacts Total</p>
                <h3 id="total-contacts" class="text-2xl font-extrabold text-gray-800 mt-0.5">--</h3>
            </div>
        </div>

        <!-- Total Groupes -->
        <div class="bg-white rounded-2xl p-4 shadow-sm border border-gray-100 flex flex-col justify-between hover:shadow-md transition-shadow">
            <div class="flex items-center justify-between mb-2">
                <div class="p-2 bg-yellow-50 text-yellow-600 rounded-xl">
                    <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"></path></svg>
                </div>
                <span class="text-green-500 text-xs font-bold bg-green-50 px-1.5 py-0.5 rounded-md">+10%</span>
            </div>
            <div>
                <p class="text-gray-400 text-xs font-medium uppercase tracking-wider">Groupes</p>
                <h3 id="total-groupes" class="text-2xl font-extrabold text-gray-800 mt-0.5">--</h3>
            </div>
        </div>

        <!-- Invitations -->
        <div class="bg-white rounded-2xl p-4 shadow-sm border border-gray-100 flex flex-col justify-between hover:shadow-md transition-shadow">
            <div class="flex items-center justify-between mb-2">
                <div class="p-2 bg-purple-50 text-purple-600 rounded-xl">
                    <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="2" y="6" width="20" height="14" rx="2"/>
                        <path d="M2 6 L12 2 L22 6"/>
                        <path d="M2 6 L12 13 L22 6"/>
                    </svg>
                </div>
                <span class="text-sky-500 text-xs font-bold bg-sky-50 px-1.5 py-0.5 rounded-md">+10%</span>
            </div>
            <div>
                <p class="text-gray-400 text-xs font-medium uppercase tracking-wider">Invitations</p>
                <h3 id="invites-count" class="text-2xl font-extrabold text-gray-800 mt-0.5">--</h3>
            </div>
        </div>

        <!-- Places Vendues -->
        <div class="bg-white rounded-2xl p-4 shadow-sm border border-gray-100 flex flex-col justify-between hover:shadow-md transition-shadow">
            <div class="flex items-center justify-between mb-2">
                <div class="p-2 bg-green-50 text-green-600 rounded-xl">
                    <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 12V8H6a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v1M4 11v8a2 2 0 0 0 2 2h10"></path><path d="M16 13h4v4h-4z"></path></svg>
                </div>
                <span class="text-green-500 text-xs font-bold bg-green-50 px-1.5 py-0.5 rounded-md">+10%</span>
            </div>
            <div>
                <p class="text-gray-400 text-xs font-medium uppercase tracking-wider">Places Vendues</p>
                <h3 id="places-count" class="text-2xl font-extrabold text-gray-800 mt-0.5">--</h3>
            </div>
        </div>
    </div>

    <!-- Charts Section (S'étire pour combler le bas de l'écran) -->
    <div class="grid grid-cols-1 xl:grid-cols-2 gap-4 flex-1">
        <!-- Affluence Chart -->
        <div class="bg-white rounded-2xl p-5 shadow-sm border border-gray-100 flex flex-col justify-between">
            <div class="flex items-center justify-between mb-2 shrink-0">
                <h3 class="text-lg font-bold text-gray-800">Taux d'affluence</h3>
                <div class="badge badge-sm badge-outline text-gray-400">Mensuel</div>
            </div>
            <div class="flex-1 min-h-0 relative">
                <canvas id="affluenceChart" class="w-full h-full"></canvas>
            </div>
        </div>

        <!-- Distribution Chart -->
        <div class="bg-white rounded-2xl p-5 shadow-sm border border-gray-100 flex flex-col justify-between">
            <div class="flex items-center justify-between mb-2 shrink-0">
                <h3 class="text-lg font-bold text-gray-800">Répartition Invitations / Ventes</h3>
            </div>
            <div class="flex flex-col sm:flex-row items-center gap-4 flex-1 min-h-0">
                <div class="relative h-full aspect-square shrink-0 max-h-[220px]">
                    <canvas id="StatsChart"></canvas>
                </div>
                <div class="flex-1 space-y-2 w-full justify-center flex flex-col">
                    <div class="flex items-center justify-between p-2 bg-gray-50 rounded-xl text-sm">
                        <span class="flex items-center gap-2 font-medium text-gray-600">
                            <span class="w-2.5 h-2.5 rounded-full bg-principal"></span>
                            Places Vendues
                        </span>
                        <span class="font-bold text-gray-800">23.1%</span>
                    </div>
                    <div class="flex items-center justify-between p-2 bg-gray-50 rounded-xl text-sm">
                        <span class="flex items-center gap-2 font-medium text-gray-600">
                            <span class="w-2.5 h-2.5 rounded-full bg-gray-300"></span>
                            Invitations
                        </span>
                        <span class="font-bold text-gray-800">76.9%</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block scripts %}
    <script type="module" src="/frontend/src/script/dashboard.js" defer></script>
    <script type="module" src="/frontend/src/script/Charts.js" defer></script>
{% endblock %}