{% extends "layouts/base.html.twig" %}

{% block title %}Statistiques - Nice Volley Ball{% endblock %}

{% block content %}
<div class="space-y-8">
    <!-- Header -->
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
        <div>
            <h1 class="text-3xl font-bold text-gray-800">Analytique & Statistiques</h1>
            <p class="text-gray-500">Vue d'ensemble des performances et de l'engagement.</p>
        </div>
        <div class="flex items-center gap-2">
            <span class="text-sm font-medium text-gray-400 bg-white px-4 py-2 rounded-xl shadow-sm border border-gray-100">
                Période : Saison 2023-2024
            </span>
        </div>
    </div>

    <!-- Main Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
        
        <!-- Left Column: Core Metrics -->
        <div class="lg:col-span-7 space-y-8">
            
            <!-- Supporters Summary -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <!-- Supporters Totaux -->
                <div class="bg-white rounded-3xl p-6 shadow-sm border border-gray-100 flex flex-col hover:shadow-md transition-shadow stats-card">
                    <div class="flex items-center gap-4 mb-4">
                        <div class="p-3 bg-blue-50 text-principal rounded-2xl">
                            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path></svg>
                        </div>
                        <div>
                            <p class="text-3xl font-black text-gray-800">0</p>
                            <p class="text-sm font-bold text-principal uppercase tracking-tighter">Supporters totaux</p>
                        </div>
                    </div>
                    <div class="mt-auto">
                        <span class="text-sky-500 text-xs font-bold bg-sky-50 px-2 py-1 rounded-lg">↑ 0% ce mois</span>
                    </div>
                </div>

                <!-- Nouveaux Supporters -->
                <div class="bg-white rounded-3xl p-6 shadow-sm border border-gray-100 flex flex-col hover:shadow-md transition-shadow stats-card">
                    <div class="flex items-center gap-4 mb-4">
                        <div class="p-3 bg-yellow-50 text-secondaire rounded-2xl">
                            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z"></path></svg>
                        </div>
                        <div>
                            <p class="text-3xl font-black text-gray-800">0</p>
                            <p class="text-sm font-bold text-principal uppercase tracking-tighter">Nouveaux ce mois</p>
                        </div>
                    </div>
                    <div class="mt-auto">
                        <span class="text-green-500 text-xs font-bold bg-green-50 px-2 py-1 rounded-lg">Objectif : 200</span>
                    </div>
                </div>
            </div>

            <!-- Clients Chart -->
            <div class="bg-white rounded-3xl p-8 shadow-sm border border-gray-100">
                <div class="flex items-center justify-between mb-8">
                    <div>
                        <h3 class="text-xl font-bold text-gray-800">Clients Totaux</h3>
                        <p class="text-sm text-gray-400">Évolution de la base client</p>
                    </div>
                    <div class="text-right">
                        <p class="text-2xl font-black text-principal" id="clients-total-count">0</p>
                        <span class="text-green-500 text-xs font-bold" id="clients-growth">+0%</span>
                    </div>
                </div>
                <!-- Mini visualization placeholder or actual chart -->
                <div class="h-64 w-full" id="chart-clients-total">
                    <div class="flex gap-2 justify-center py-4">
                        {% for i in 1..8 %}
                        <div class="w-8 h-8 rounded-full bg-blue-50 flex items-center justify-center text-principal">
                            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z"></path></svg>
                        </div>
                        {% endfor %}
                        <div class="w-8 h-8 rounded-full bg-yellow-50 flex items-center justify-center text-secondaire font-bold text-xs">+</div>
                    </div>
                </div>
            </div>

            <!-- Places Vendues -->
            <div class="bg-white rounded-3xl p-8 shadow-sm border border-gray-100 flex flex-col md:flex-row items-center gap-8">
                <div class="flex-1">
                    <h3 class="text-xl font-bold text-gray-800 mb-2">Places Vendues</h3>
                    <p class="text-4xl font-black text-principal mb-2" id="places-sold-count">0</p>
                    <p class="text-sky-500 text-sm font-bold flex items-center gap-1">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path></svg>
                        <span id="places-sold-growth">+0%</span> du dernier mois
                    </p>
                </div>
                <div class="w-full md:w-64 h-32 bg-gray-50 rounded-2xl overflow-hidden" id="chart-places-sold">
                    <!-- Bar Chart logic -->
                </div>
            </div>

            <!-- Affluence Curve -->
            <div class="bg-principal rounded-3xl p-8 shadow-xl shadow-principal/10 text-white">
                <div class="flex items-center justify-between mb-8">
                    <h3 class="text-xl font-bold">Courbe d'affluence</h3>
                    <div class="px-3 py-1 bg-white/10 rounded-lg text-xs font-bold uppercase tracking-widest">Temps réel</div>
                </div>
                <div class="h-48 relative">
                     <!-- SVG Curve from original but styled -->
                     <svg viewBox="0 0 500 120" class="w-full h-full" preserveAspectRatio="none">
                        <polyline fill="none" stroke="#F5D804" stroke-width="4" stroke-linecap="round" stroke-linejoin="round" points="0,90 40,75 80,85 120,60 160,50 200,65 240,40 280,45 320,25 360,35 400,15 440,20 500,5" />
                        <path d="M0,120 L0,90 40,75 80,85 120,60 160,50 200,65 240,40 280,45 320,25 360,35 400,15 440,20 500,5 L500,120 Z" fill="url(#grad)" fill-opacity="0.2" />
                        <defs>
                            <linearGradient id="grad" x1="0%" y1="0%" x2="0%" y2="100%">
                                <stop offset="0%" style="stop-color:#F5D804;stop-opacity:1" />
                                <stop offset="100%" style="stop-color:#F5D804;stop-opacity:0" />
                            </linearGradient>
                        </defs>
                    </svg>
                </div>
                <div class="flex justify-between mt-4 text-[10px] font-bold text-white/50 uppercase">
                    <span>Sep</span><span>Oct</span><span>Nov</span><span>Déc</span><span>Jan</span><span>Fév</span><span>Mar</span><span>Avr</span><span>Mai</span><span>Jun</span><span>Jul</span><span>Août</span>
                </div>
            </div>
        </div>

        <!-- Right Column: Marketing & Others -->
        <div class="lg:col-span-5 space-y-8">
            
            <!-- Email Campaigns -->
            <div class="bg-white rounded-3xl p-8 shadow-sm border border-gray-100 flex flex-col items-center">
                <h3 class="text-xl font-bold text-gray-800 mb-8 w-full">Campagnes Emails</h3>
                <div class="w-full p-6 bg-gray-50 rounded-2xl mb-8 flex items-center gap-6">
                    <div class="p-4 bg-white rounded-xl shadow-sm">
                        <svg class="w-8 h-8 text-principal" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
                    </div>
                    <div>
                        <p class="text-2xl font-black text-gray-800">27,239</p>
                        <p class="text-sm font-medium text-gray-400 leading-tight text-balance">Mails envoyés via Brevo (Quota 40k)</p>
                    </div>
                </div>
                <div class="w-full h-64" id="chart-mail">
                    <!-- Donut chart for quota -->
                </div>
            </div>

            <!-- Double Small Stats -->
            <div class="grid grid-cols-2 gap-6">
                <div class="bg-white rounded-3xl p-6 shadow-sm border border-gray-100 text-center space-y-2">
                    <p class="text-3xl font-black text-principal">783</p>
                    <p class="text-xs font-bold text-gray-400 uppercase tracking-wider">Places Invités</p>
                    <div class="text-[10px] font-bold text-sky-500 bg-sky-50 py-1 rounded-full">+10%</div>
                </div>
                <div class="bg-white rounded-3xl p-6 shadow-sm border border-gray-100 text-center space-y-2">
                    <p class="text-3xl font-black text-principal">6</p>
                    <p class="text-xs font-bold text-gray-400 uppercase tracking-wider">Segments actifs</p>
                    <div class="text-[10px] font-bold text-green-500 bg-green-50 py-1 rounded-full">Optimal</div>
                </div>
            </div>

            <!-- Invitations Circular -->
            <div class="bg-white rounded-3xl p-8 shadow-sm border border-gray-100 flex items-center justify-between gap-8 hover:shadow-md transition-shadow">
                <div class="space-y-2">
                    <h3 class="text-lg font-bold text-gray-800">Invitations</h3>
                    <p class="text-4xl font-black text-principal">10,128</p>
                    <p class="text-xs font-bold text-sky-500 tracking-tight">↑ + 10% DU DERNIER MOIS</p>
                </div>
                <div class="w-28 h-28 relative shrink-0">
                    <!-- Progress ring -->
                    <svg viewBox="0 0 36 36" class="w-full h-full transform -rotate-90">
                        <circle cx="18" cy="18" r="16" fill="none" class="stroke-gray-100" stroke-width="4"></circle>
                        <circle cx="18" cy="18" r="16" fill="none" class="stroke-principal" stroke-width="4" stroke-dasharray="75, 100" stroke-linecap="round"></circle>
                    </svg>
                    <div class="absolute inset-0 flex items-center justify-center font-black text-principal text-lg">75%</div>
                </div>
            </div>

        </div>
    </div>
</div>
{% endblock %}

{% block scripts %}
    <script src="https://cdn.jsdelivr.net/npm/apexcharts" defer></script>
    <script type="module" src="/frontend/src/script/chart-clients-total.js" defer></script>
    <script type="module" src="/frontend/src/script/chart-places-sold.js" defer></script>
{% endblock %}
