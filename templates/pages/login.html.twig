<!DOCTYPE html>
<html lang="fr" data-theme="light">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Connexion - Nice Volley Ball</title>

    <!-- Tailwind CSS & DaisyUI CDN -->
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdn.jsdelivr.net/npm/daisyui@latest/dist/full.min.css" rel="stylesheet" type="text/css" />

    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        principal: '#15277B',
                        secondaire: '#F5D804',
                        background: '#363636',
                    }
                }
            }
        }
    </script>
    
    <link rel="stylesheet" href="/frontend/src/style/style.css">
    <link rel="icon" type="image/svg+xml" href="/frontend/src/assets/logo.svg" />
</head>
<body class="bg-gray-50 flex flex-col min-h-screen">

    <!-- Main Content -->
    <main class="flex-1 flex flex-col lg:flex-row relative overflow-hidden">
        
        <!-- Left Side: Visual/Logo (Desktop) -->
        <div class="hidden lg:flex lg:w-1/2 bg-principal relative items-center justify-center p-12 overflow-hidden">
            <!-- Decorative Elements -->
            <div class="absolute top-0 left-0 w-64 h-64 bg-white/5 rounded-full -translate-x-1/2 -translate-y-1/2"></div>
            <div class="absolute bottom-0 right-0 w-96 h-96 bg-secondaire/10 rounded-full translate-x-1/3 translate-y-1/3"></div>
            
            <div class="relative text-center z-10">
                <img src="/frontend/src/assets/logo.svg" alt="Nice Volley Ball" class="w-80 h-auto mb-8 drop-shadow-2xl mx-auto" />
                <h1 class="text-4xl font-black text-white uppercase tracking-widest">CRM Management</h1>
                <div class="w-24 h-1 bg-secondaire mx-auto mt-4 rounded-full"></div>
            </div>
        </div>

        <!-- Right Side: Login Form -->
        <div class="flex-1 flex flex-col justify-center items-center px-6 py-12 lg:p-20 bg-white">
            
            <!-- Mobile Logo -->
            <div class="lg:hidden mb-12">
                <img src="/frontend/src/assets/logo.svg" alt="Nice Volley Ball" class="h-24 w-auto drop-shadow-md" />
            </div>

            <div class="w-full max-w-md">
                <div class="mb-10 text-center lg:text-left">
                    <h2 class="text-3xl font-black text-gray-800 mb-2 tracking-tight">Connexion</h2>
                    <p class="text-gray-400 font-medium">Accédez à votre espace de gestion Nice Volley Ball.</p>
                </div>

                <form action="/login" method="POST" class="space-y-6">
                    <div class="form-control w-full">
                        <label class="label font-bold text-gray-700 text-xs uppercase tracking-widest px-1" for="identifiant">
                            Identifiant
                        </label>
                        <div class="relative">
                            <span class="absolute inset-y-0 left-0 flex items-center pl-4 text-gray-400">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
                            </span>
                            <input 
                                type="text" 
                                name="identifiant" 
                                id="identifiant" 
                                placeholder="Entrer votre identifiant"
                                class="input input-bordered w-full h-14 pl-12 rounded-2xl bg-gray-50 border-gray-100 focus:border-principal focus:ring-4 focus:ring-principal/5 transition-all outline-none" 
                                required 
                            />
                        </div>
                    </div>

                    <div class="form-control w-full">
                        <label class="label font-bold text-gray-700 text-xs uppercase tracking-widest px-1" for="password">
                            Mot de passe
                        </label>
                        <div class="relative">
                            <span class="absolute inset-y-0 left-0 flex items-center pl-4 text-gray-400">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path></svg>
                            </span>
                            <input 
                                type="password" 
                                name="password" 
                                id="password" 
                                placeholder="••••••••"
                                class="input input-bordered w-full h-14 pl-12 rounded-2xl bg-gray-50 border-gray-100 focus:border-principal focus:ring-4 focus:ring-principal/5 transition-all outline-none" 
                                required 
                            />
                        </div>
                    </div>

                    {% if error %}
                    <div class="alert alert-error bg-red-50 border-none rounded-2xl p-4 flex items-center gap-3 text-red-600 text-sm font-bold">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                        {{ error }}
                    </div>
                    {% endif %}

                    <button type="submit" class="btn btn-block h-14 bg-principal hover:bg-principal/90 text-white rounded-2xl border-none text-lg font-bold shadow-lg shadow-principal/20 normal-case">
                        Se connecter
                    </button>
                </form>
            </div>
        </div>

        <!-- Decorative Bottom Shape -->
        <div class="absolute bottom-0 left-0 right-0 h-12 bg-secondaire pointer-events-none opacity-20 lg:opacity-100 lg:bg-secondaire" style="clip-path: polygon(0 100%, 100% 100%, 100% 0);"></div>
    </main>

    <!-- Footer -->
    <footer class="bg-gray-900 text-white/40 py-8 px-6 lg:px-20 border-t border-white/5">
        <div class="max-w-[1400px] mx-auto flex flex-col md:flex-row items-center justify-between gap-6">
            <div class="flex flex-col md:flex-row items-center gap-4 md:gap-8 text-xs font-bold uppercase tracking-widest">
                <a href="mailto:secretariat@nicevolleyball.fr" class="hover:text-white transition-colors">secretariat@nicevolleyball.fr</a>
                <a href="tel:0493871277" class="hover:text-white transition-colors">04 93 87 12 77</a>
                <a href="mailto:info@nicevolleyball.fr" class="hover:text-white transition-colors">info@nicevolleyball.fr</a>
            </div>
            <div class="flex flex-col items-center md:items-end gap-1">
                <p class="text-[10px] font-medium tracking-widest uppercase">Nice Volley Ball © 2026</p>
                <p class="text-[9px] font-medium tracking-widest uppercase text-white/20">Réalisé par la promo BTS SIO IRIS 2025-2027</p>
            </div>
        </div>
    </footer>

</body>
</html>
