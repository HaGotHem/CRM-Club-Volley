{
    "name": "user/nvb-dashboard-api",
    "description": "Dashboard Nice Volley Ball",
    "require": {
        "slim/slim": "4.*",
        "slim/psr7": "^1.8",
        "vlucas/phpdotenv": "^5.6",
        "guzzlehttp/guzzle": "^7.11",
        "getbrevo/brevo-php": "^4.0",
        "slim/twig-view": "3.3"
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true
        }
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    }
}
